# ── Segurança ─────────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave-secreta-em-producao

# ── Banco de dados ────────────────────────────────────────────────────────────
# Em produção (docker-compose), a DATABASE_URL é sobrescrita pelo compose
# usando as variáveis POSTGRES_* abaixo
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/saas_waha
POSTGRES_DB=saas_waha
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-a-senha-do-postgres

# ── WAHA API ──────────────────────────────────────────────────────────────────
WAHA_API_URL=https://waha-waha.xeramr.easypanel.host
WAHA_API_KEY=wARM31Ngadmin
# URL pública do backend para receber eventos do WAHA
WAHA_WEBHOOK_URL=https://api-saas.xeramr.easypanel.host/api/webhook/waha

# ── Mercado Pago ──────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxxxxxx
MP_WEBHOOK_SECRET=

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL pública do frontend (usada no CORS e em redirects de pagamento)
FRONTEND_URL=https://saas.xeramr.easypanel.host

# ── Modo debug ────────────────────────────────────────────────────────────────
DEBUG=false
