# Backend production env example
# Copy to .env and fill values before deploy

# Database (if using external DB) or keep docker-compose postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/saas_waha
POSTGRES_DB=saas_waha
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# App
SECRET_KEY=troque-esta-chave-secreta-em-producao
DEBUG=False

# WAHA (WhatsApp) Integration
WAHA_API_URL=https://waha-waha.xeramr.easypanel.host
WAHA_API_KEY=cole-aqui-sua-waha-api-key
WAHA_WEBHOOK_URL=https://your-backend-domain.com/api/webhook/waha

# Frontend public URL (usado para webhook/redirects)
FRONTEND_URL=https://your-frontend-domain.com

# Mercado Pago
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# Other optional
# LOG_LEVEL=info
