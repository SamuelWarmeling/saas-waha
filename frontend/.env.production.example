# Frontend production env example
# Copy to .env and set FRONTEND_URL if used by backend or builds
VITE_API_BASE_URL=https://your-backend-domain.com
VITE_APP_NAME=WahaSaaS

# If you want the frontend to know its public URL
VITE_FRONTEND_URL=https://your-frontend-domain.com

# Sentry (monitoramento de erros no frontend)
VITE_SENTRY_DSN=https://xxxxxxxxxxxx@oXXXXXXX.ingest.sentry.io/XXXXXXX

# PostHog (analytics de produto)
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxx
VITE_POSTHOG_HOST=https://app.posthog.com
